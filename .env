# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://app:app@127.0.0.1:3306/amoobot?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> app/telegram ###
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change_this_secret
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_MODE=long_polling
# allowed: webhook, long_polling
TELEGRAM_PROXY=
# optional: socks5://host:1080  socks5://user:pass@host:1080  http://host:port
###< app/telegram ###

###> app/payment ###
PAYMENT_CARD_NUMBER=
PAYMENT_CARD_HOLDER=
PAYMENT_DESCRIPTION=
###< app/payment ###

###> app/admin ###
ADMIN_PASSWORD=admin
###< app/admin ###

###> app/panel_proxy ###
PANEL_PROXY_ENABLED=false
PANEL_PROXY_TYPE=socks5
PANEL_PROXY_HOST=
PANEL_PROXY_PORT=
PANEL_PROXY_USERNAME=
PANEL_PROXY_PASSWORD=
PANEL_PROXY_TIMEOUT=30
###< app/panel_proxy ###

###> app/service_notifications ###
SERVICE_NOTIFY_EXPIRY_DAYS=3,1
SERVICE_NOTIFY_TRAFFIC_THRESHOLDS=80,95,100
###< app/service_notifications ###

###> app/renewal_policy ###
RENEWAL_CARRY_REMAINING_TRAFFIC=true
RENEWAL_CARRY_REMAINING_DAYS=true
RENEWAL_EXPIRED_START_FROM_NOW=true
###< app/renewal_policy ###

###> app/pricing ###
PRICING_GLOBAL_DISCOUNT_PERCENT=0
###< app/pricing ###
