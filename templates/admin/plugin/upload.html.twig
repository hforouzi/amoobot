{% extends 'admin/custom_page.html.twig' %}
{% trans_default_domain 'admin' %}

{% block page_section %}{{ 'admin.plugins'|trans }}{% endblock %}
{% block page_title %}{{ 'plugin.upload_title'|trans }}{% endblock %}

{% block body %}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="admin-form-card">
        <div class="admin-form-heading">
            <h2>{{ 'plugin.upload_title'|trans }}</h2>
            <p class="admin-muted">{{ 'plugin.upload_help'|trans }}</p>
        </div>

        {{ form_start(form) }}
            <div class="admin-form-row">
                {{ form_row(form.pluginZip) }}
            </div>

            <div class="admin-actions">
                <button class="btn btn-primary" type="submit">
                    <i class="fa fa-upload"></i>
                    {{ 'plugin.install'|trans }}
                </button>
                <a class="btn btn-secondary" href="{{ listUrl }}">{{ 'common.back'|trans }}</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
