{% extends '@EasyAdmin/page/content.html.twig' %}
{% trans_default_domain 'admin' %}

{% block content_title %}{{ 'renewal_pricing_settings.title'|trans }}{% endblock %}

{% block main %}
    <div class="admin-custom-page admin-settings-page">
    <form method="post" class="admin-form-card admin-settings-form">
        <div class="admin-section">
            <h2>{{ 'renewal_pricing_settings.sections.renewal'|trans }}</h2>

            <div class="admin-checkbox-row">
                <input class="form-check-input" type="checkbox" id="renewal_carry_remaining_traffic" name="renewal_carry_remaining_traffic" {% if values.renewal_carry_remaining_traffic %}checked{% endif %}>
                <label class="form-check-label" for="renewal_carry_remaining_traffic">{{ 'renewal_pricing_settings.fields.carry_remaining_traffic'|trans }}</label>
            </div>
            <div class="admin-checkbox-row">
                <input class="form-check-input" type="checkbox" id="renewal_carry_remaining_days" name="renewal_carry_remaining_days" {% if values.renewal_carry_remaining_days %}checked{% endif %}>
                <label class="form-check-label" for="renewal_carry_remaining_days">{{ 'renewal_pricing_settings.fields.carry_remaining_days'|trans }}</label>
            </div>
            <div class="admin-checkbox-row">
                <input class="form-check-input" type="checkbox" id="renewal_expired_start_from_now" name="renewal_expired_start_from_now" {% if values.renewal_expired_start_from_now %}checked{% endif %}>
                <label class="form-check-label" for="renewal_expired_start_from_now">{{ 'renewal_pricing_settings.fields.expired_start_from_now'|trans }}</label>
            </div>
        </div>

        <div class="admin-section">
            <h2>{{ 'renewal_pricing_settings.sections.pricing'|trans }}</h2>

            <div class="admin-form-grid">
                <div class="admin-form-row">
                    <label class="form-label" for="pricing_global_discount_percent">{{ 'renewal_pricing_settings.fields.global_discount_percent'|trans }}</label>
                    <input class="form-control" type="number" min="0" max="100" step="1" id="pricing_global_discount_percent" name="pricing_global_discount_percent" value="{{ values.pricing_global_discount_percent }}">
                    <div class="form-text">{{ 'renewal_pricing_settings.help.global_discount_percent'|trans }}</div>
                </div>
            </div>
        </div>

        <div class="admin-section">
            <h2>{{ 'renewal_pricing_settings.sections.traffic_addon'|trans }}</h2>

            <div class="admin-checkbox-row">
                <input class="form-check-input" type="checkbox" id="traffic_addon_enabled" name="traffic_addon_enabled" {% if values.traffic_addon_enabled %}checked{% endif %}>
                <label class="form-check-label" for="traffic_addon_enabled">{{ 'renewal_pricing_settings.fields.traffic_addon_enabled'|trans }}</label>
            </div>

            <div class="admin-form-grid">
                <div class="admin-form-row">
                    <label class="form-label" for="traffic_addon_min_gb">{{ 'renewal_pricing_settings.fields.traffic_addon_min_gb'|trans }}</label>
                    <input class="form-control" type="number" min="1" step="1" id="traffic_addon_min_gb" name="traffic_addon_min_gb" value="{{ values.traffic_addon_min_gb }}">
                </div>
                <div class="admin-form-row">
                    <label class="form-label" for="traffic_addon_max_gb">{{ 'renewal_pricing_settings.fields.traffic_addon_max_gb'|trans }}</label>
                    <input class="form-control" type="number" min="1" step="1" id="traffic_addon_max_gb" name="traffic_addon_max_gb" value="{{ values.traffic_addon_max_gb }}">
                </div>
                <div class="admin-form-row">
                    <label class="form-label" for="traffic_addon_price_per_gb">{{ 'renewal_pricing_settings.fields.traffic_addon_price_per_gb'|trans }}</label>
                    <input class="form-control" type="number" min="0" step="1" id="traffic_addon_price_per_gb" name="traffic_addon_price_per_gb" value="{{ values.traffic_addon_price_per_gb }}">
                </div>
            </div>
        </div>

        <div class="admin-section">
            <h2>{{ 'renewal_pricing_settings.sections.sales_status'|trans }}</h2>

            <div class="admin-checkbox-row">
                <input class="form-check-input" type="checkbox" id="sales_new_orders_enabled" name="sales_new_orders_enabled" {% if values.sales_new_orders_enabled %}checked{% endif %}>
                <label class="form-check-label" for="sales_new_orders_enabled">{{ 'renewal_pricing_settings.fields.sales_new_orders_enabled'|trans }}</label>
                <div class="form-text">{{ keys.sales_new_orders_enabled }}</div>
            </div>
            <div class="admin-checkbox-row">
                <input class="form-check-input" type="checkbox" id="sales_renewals_enabled" name="sales_renewals_enabled" {% if values.sales_renewals_enabled %}checked{% endif %}>
                <label class="form-check-label" for="sales_renewals_enabled">{{ 'renewal_pricing_settings.fields.sales_renewals_enabled'|trans }}</label>
                <div class="form-text">{{ keys.sales_renewals_enabled }}</div>
            </div>
            <div class="admin-checkbox-row">
                <input class="form-check-input" type="checkbox" id="sales_add_traffic_enabled" name="sales_add_traffic_enabled" {% if values.sales_add_traffic_enabled %}checked{% endif %}>
                <label class="form-check-label" for="sales_add_traffic_enabled">{{ 'renewal_pricing_settings.fields.sales_add_traffic_enabled'|trans }}</label>
                <div class="form-text">{{ keys.sales_add_traffic_enabled }}</div>
            </div>

            <div class="admin-form-row">
                <label class="form-label" for="sales_disabled_message">{{ 'renewal_pricing_settings.fields.sales_disabled_message'|trans }}</label>
                <textarea class="form-control" id="sales_disabled_message" name="sales_disabled_message" rows="4">{{ values.sales_disabled_message }}</textarea>
                <div class="form-text">{{ keys.sales_disabled_message }}</div>
            </div>
        </div>

        <div class="admin-actions">
            <button type="submit" class="btn btn-primary">{{ 'common.save'|trans }}</button>
        </div>
    </form>
    </div>
{% endblock %}
